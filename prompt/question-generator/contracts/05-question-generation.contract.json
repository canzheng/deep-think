{
  "stage": "question_generation",
  "reads_required": ["routing", "structure", "scenarios"],
  "reads_optional": [
    {
      "stage": "boundary",
      "kind": "situation",
      "when": [
        "scope is still fragile",
        "unit of analysis may be confused",
        "time horizon ambiguity still matters",
        "multiple workers may have caused scope drift"
      ]
    },
    {
      "stage": "decision_logic",
      "kind": "user_requirement",
      "when": [
        "you want explicitly action-sensitive questions"
      ]
    },
    {
      "stage": "evidence_planning",
      "kind": "user_requirement",
      "when": [
        "you want questions constrained by available proof paths"
      ]
    }
  ],
  "depends_on": ["task", "domain", "output_mode", "evidence_mode", "uncertainty_mode", "decision_mode"],
  "writes": ["questions"],
  "output_format": "json_state_update",
  "output_schema": {
    "type": "object",
    "required": ["questions"],
    "properties": {
      "questions": {
        "type": "object",
        "required": [
          "clarifying",
          "structural",
          "stakeholder",
          "evidence",
          "task_specific",
          "domain_specific",
          "output_mode_specific",
          "evidence_mode_specific",
          "uncertainty_mode_specific",
          "decision_mode_specific",
          "top_killer_questions"
        ],
        "properties": {
          "clarifying": {"type": "array", "items": {"$ref": "#/$defs/question"}},
          "structural": {"type": "array", "items": {"$ref": "#/$defs/question"}},
          "stakeholder": {"type": "array", "items": {"$ref": "#/$defs/question"}},
          "evidence": {"type": "array", "items": {"$ref": "#/$defs/question"}},
          "task_specific": {"type": "array", "items": {"$ref": "#/$defs/question"}},
          "domain_specific": {"type": "array", "items": {"$ref": "#/$defs/question"}},
          "output_mode_specific": {"type": "array", "items": {"$ref": "#/$defs/question"}},
          "evidence_mode_specific": {"type": "array", "items": {"$ref": "#/$defs/question"}},
          "uncertainty_mode_specific": {"type": "array", "items": {"$ref": "#/$defs/question"}},
          "decision_mode_specific": {"type": "array", "items": {"$ref": "#/$defs/question"}},
          "top_killer_questions": {"type": "array", "items": {"$ref": "#/$defs/question"}}
        },
        "additionalProperties": false
      }
    },
    "$defs": {
      "question": {
        "type": "object",
        "required": [
          "question",
          "why_it_matters",
          "impact_on_final_judgment",
          "uncertainty_reduction",
          "observability",
          "reducibility",
          "decision_change_types"
        ],
        "properties": {
          "question": {"type": "string"},
          "why_it_matters": {"type": "string"},
          "impact_on_final_judgment": {"type": "string"},
          "uncertainty_reduction": {"type": "string"},
          "observability": {"type": "string"},
          "reducibility": {"type": "string"},
          "decision_change_types": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  },
  "feedback": {
    "supported": true,
    "field": "feedback",
    "schema": {
      "needed": false,
      "target_stage": "structure",
      "reason": "",
      "state_sections_to_revisit": ["structure"],
      "invalidate_downstream_sections": ["questions", "evidence_plan", "uncertainty_map", "decision_logic", "signals", "monitoring", "synthesis"]
    }
  }
}
