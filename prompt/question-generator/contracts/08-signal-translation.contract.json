{
  "stage": "signal_translation",
  "reads_required": ["routing", "question_generation", "scenarios", "evidence_planning"],
  "reads_optional": [
    {
      "stage": "decision_logic",
      "kind": "user_requirement",
      "when": [
        "signals should trigger action, not just belief updates",
        "staging, scaling, or kill criteria must be reflected"
      ]
    },
    {
      "stage": "structure",
      "kind": "situation",
      "when": [
        "signals should track bottlenecks or latent drivers directly"
      ]
    }
  ],
  "depends_on": ["task", "domain", "output_mode", "evidence_mode", "uncertainty_mode", "decision_mode"],
  "writes": ["signals"],
  "output_format": "json_state_update",
  "output_schema": {
    "type": "object",
    "required": ["signals"],
    "properties": {
      "signals": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "signal",
            "linked_question",
            "preferred_evidence_source",
            "backup_evidence_source",
            "cadence",
            "thresholds",
            "update_rules",
            "belief_update_implications",
            "confidence_under_current_uncertainty_mode",
            "changes_action_vs_belief"
          ],
          "properties": {
            "signal": {"type": "string"},
            "linked_question": {"type": "string"},
            "preferred_evidence_source": {"type": "string"},
            "backup_evidence_source": {"type": "string"},
            "cadence": {"type": "string"},
            "thresholds": {"type": "array", "items": {"type": "string"}},
            "update_rules": {"type": "array", "items": {"type": "string"}},
            "belief_update_implications": {"type": "array", "items": {"type": "string"}},
            "confidence_under_current_uncertainty_mode": {"type": "string"},
            "changes_action_vs_belief": {"type": "string"}
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  },
  "feedback": {
    "supported": false
  }
}
