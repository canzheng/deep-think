{
  "stage": "evidence_planning",
  "reads_required": ["routing", "structure", "scenarios", "question_generation"],
  "reads_optional": [
    {
      "stage": "boundary",
      "kind": "situation",
      "when": [
        "source selection depends strongly on what is in vs out of scope",
        "adjacent systems could create source creep"
      ]
    },
    {
      "stage": "decision_logic",
      "kind": "user_requirement",
      "when": [
        "evidence planning must already align to stage-gates or action thresholds"
      ]
    }
  ],
  "depends_on": ["task", "domain", "output_mode", "evidence_mode", "uncertainty_mode", "decision_mode"],
  "writes": ["evidence_plan", "uncertainty_map"],
  "output_format": "json_state_update",
  "output_schema": {
    "type": "object",
    "required": ["evidence_plan", "uncertainty_map"],
    "properties": {
      "evidence_plan": {
        "type": "object",
        "required": [
          "evidence_hierarchy",
          "preferred_source_types",
          "backup_source_types",
          "conflict_resolution_rules",
          "question_to_evidence_mapping"
        ],
        "properties": {
          "evidence_hierarchy": {"type": "array", "items": {"type": "string"}},
          "preferred_source_types": {"type": "array", "items": {"type": "string"}},
          "backup_source_types": {"type": "array", "items": {"type": "string"}},
          "conflict_resolution_rules": {"type": "array", "items": {"type": "string"}},
          "question_to_evidence_mapping": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["question", "preferred_sources", "backup_sources"],
              "properties": {
                "question": {"type": "string"},
                "preferred_sources": {"type": "array", "items": {"type": "string"}},
                "backup_sources": {"type": "array", "items": {"type": "string"}}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      },
      "uncertainty_map": {
        "type": "object",
        "required": [
          "reducible_unknowns",
          "partially_reducible_unknowns",
          "irreducible_uncertainties",
          "task_material_uncertainties"
        ],
        "properties": {
          "reducible_unknowns": {"type": "array", "items": {"type": "string"}},
          "partially_reducible_unknowns": {"type": "array", "items": {"type": "string"}},
          "irreducible_uncertainties": {"type": "array", "items": {"type": "string"}},
          "task_material_uncertainties": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  },
  "feedback": {
    "supported": true,
    "field": "feedback",
    "schema": {
      "needed": false,
      "target_stage": "scenarios",
      "reason": "",
      "state_sections_to_revisit": ["scenarios"],
      "invalidate_downstream_sections": ["evidence_plan", "uncertainty_map", "decision_logic", "signals", "monitoring", "synthesis"]
    }
  }
}
